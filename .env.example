# Neon Auth endpoint (browser-safe). Found in Neon Console → Auth → Configuration.
# Format: https://ep-xxx.neonauth.<region>.aws.neon.build/<db>/auth
VITE_NEON_AUTH_URL=

# Neon Postgres pooled connection string (server-only).
DATABASE_URL=

# Comma-separated list of email addresses allowed into /admin.
# Server-only — never read in client bundles. The email is matched against
# the verified Google email claim on the JWT, not against user input.
# Example: ADMIN_EMAILS=you@example.com,teammate@example.com
ADMIN_EMAILS=
